# העתיקי את הקובץ הזה ל־.env.local (באותה תיקייה: mom-manager)
# והדביקי מ-Supabase: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- תזכורות כשהאפליקציה סגורה (Web Push + Cron) ---
# ללא השורות הבאות: תזכורות יופיעו רק כשהדף/PWA פתוחים.
# SUPABASE_SERVICE_ROLE_KEY=        ← מ-Supabase → Settings → API → service_role (סודי)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=     ← npx web-push generate-vapid-keys
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# CRON_SECRET=                     ← מחרוזת אקראית; חובה בפרודקשן כדי ש-/api/push/cron יאושר
